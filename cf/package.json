{
  "name": "ehr-104-cf",
  "private": true,
  "version": "1.0.0",
  "description": "104 eHR LIFF app — all-Cloudflare (Workers + Hono + D1 + Durable Objects)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
