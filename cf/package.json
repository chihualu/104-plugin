    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^5.3.4",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^4.3.6"
  }
}
