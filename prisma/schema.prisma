generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserBinding {
  id                Int      @id @default(autoincrement())
  lineUserId        String   @unique
  companyId         String?  // 統編 (groupUBINo)
  internalCompanyId String?  // 內部 ID (companyID, e.g. "1")
  empId             String?  // 員編 (account)
  encryptedToken    String   // 存儲加密後的 104 Token
  iv                String   // 加密用的向量
  cookies           String?  // 存儲 104 Session Cookies
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  logs              UsageLog[]
  scheduledTasks    ScheduledTask[]
  grantsGiven       Delegation[] @relation("Granter")
  grantsReceived    Delegation[] @relation("Grantee")
}

model ScheduledTask {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        UserBinding @relation(fields: [userId], references: [id])
  scheduledAt DateTime // Target execution time
  lat         Float
  lng         Float
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, EXPIRED, CANCELLED
  result      String?  // Response from API
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scheduledAt, status])
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  user      UserBinding @relation(fields: [userId], references: [id])
  userId    Int
  actorUserId Int?    // 實際執行者 id（代理操作時=操作者；本人操作時可為 null）
  action    String   // 'CHECK_IN' | 'AUDIT'
  count     Int      // 筆數
  details   String?  // 備註 (例如日期範圍)
  createdAt DateTime @default(now())
}

// 代理授權：granter（被代理人）授權 grantee（操作者）代為操作其帳號
model Delegation {
  id         Int         @id @default(autoincrement())
  granterId  Int         // 被代理人（把權限授權出去的人）
  granter    UserBinding @relation("Granter", fields: [granterId], references: [id])
  granteeId  Int         // 操作者（被授權可代理的人）
  grantee    UserBinding @relation("Grantee", fields: [granteeId], references: [id])
  active     Boolean     @default(true)
  expiresAt  DateTime?   // 選填，到期後失效
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([granterId, granteeId])
  @@index([granteeId, active])
}
